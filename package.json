{
  "name": "pizza-pos",
  "version": "1.0.0",
  "description": "Pizza POS desktop app with ordering, kitchen tickets, shift cash, and reports",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:desktop": "concurrently \"npm run dev:frontend\" \"wait-on http://localhost:5173 && electron .\"",
    "dev:backend": "nodemon server.js",
    "dev:frontend": "npm --prefix frontend run dev",
    "build": "npm --prefix frontend run build",
    "build:desktop": "npm run build && electron-builder",
    "desktop": "electron .",
    "start": "node server.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "concurrently": "^9.2.1",
    "electron": "^41.1.1",
    "electron-builder": "^26.8.1",
    "nodemon": "^3.1.14",
    "wait-on": "^9.0.4"
  },
  "dependencies": {
    "better-sqlite3": "^12.8.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "zod": "^4.3.6"
  },
  "build": {
    "appId": "com.example.pizzapos",
    "productName": "Pizza POS",
    "directories": {
      "buildResources": "electron/assets"
    },
    "files": [
      "electron/**/*",
      "frontend/dist/**/*",
      "server.js",
      "package.json",
      "node_modules/**/*"
    ],
    "extraMetadata": {
      "main": "electron/main.cjs"
    },
    "win": {
      "target": "nsis"
    }
  }
}
